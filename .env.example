# Copie para .env e preencha com o projeto Supabase (nunca commite .env).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Opcional: mesmo valor da publishable/anon key do dashboard
# VITE_SUPABASE_ANON_KEY=
# Opcional: referência (ex.: abcdefghij) — usado em documentação/tooling
VITE_SUPABASE_PROJECT_ID=

# Capacitor Android TV — use o ficheiro .env.capacitor (ver .env.capacitor.example) OU defina na sessão:
# PowerShell: $env:CAPACITOR_SERVER_URL="https://seu-dominio.com/player"; npx cap sync android
# Opcionalmente pode colocar CAPACITOR_SERVER_URL=... neste .env — o capacitor.config.ts também lê.
